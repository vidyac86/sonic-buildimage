SPATH := $($(PYTHON_SAITHRIFT_MRVL_TERALYNX)_SRC_PATH)
DEP_FILES := $(SONIC_COMMON_FILES_LIST) $(PLATFORM_PATH)/python-saithrift.mk $(PLATFORM_PATH)/python-saithrift.dep
DEP_FILES += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES += $(shell git ls-files -- $(SPATH))

$(PYTHON_SAITHRIFT_MRVL_TERALYNX)_CACHE_MODE := GIT_CONTENT_SHA
$(PYTHON_SAITHRIFT_MRVL_TERALYNX)_DEP_FLAGS := $(SONIC_COMMON_FLAGS_LIST)
$(PYTHON_SAITHRIFT_MRVL_TERALYNX)_DEP_FILES := $(DEP_FILES)
