{# This template generates the unified frr.conf for unified/separated routing config modes.
     For non-mgmt-framework devices it delegates to frr_unified.conf.j2, which includes only
     the required sub-components (zebra interfaces, staticd routes, bgpd main config) with a
     single shared header, avoiding duplicate hostname/log directives that break vtysh -b. #}
{% if DEVICE_METADATA.localhost.frr_mgmt_framework_config is defined and DEVICE_METADATA.localhost.frr_mgmt_framework_config == "true" %}
    {% include "/usr/local/sonic/frrcfgd/frr.conf.j2" %}
{% else %}
    {% include "/usr/share/sonic/templates/frr_unified.conf.j2" %}
{% endif %}
